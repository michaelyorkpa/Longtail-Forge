# Don't upload the PID file for the node server
.node-server.pid

# Dependencies
node_modules/

# Local runtime data
data/*
!data/.gitkeep

# Local runtime logs
logs/*
!logs/.gitkeep

# Archived local data
archive/

# Ignore the logo concepts image file
images/logo-concepts.png

# Ignore the .vscode directory which may contain user-specific settings
.vscode/

# Ignore environment variable files and database files
.env
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Ignore documentation files that are not meant to be shared
AGENTS.md
DECISIONS.md
CODEREVIEW.md
ROADMAP-ARCHIVE.md
